PORT=8080
CORS_ORIGINS=http://127.0.0.1:5500,http://localhost:5500

# Firebase Admin credentials (Option A: separate fields)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"

# OR Option B: full JSON as one string
# FIREBASE_SERVICE_ACCOUNT_JSON={"project_id":"...","client_email":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"}

JWT_SECRET=replace-with-strong-random-secret
ADMIN_EMAIL=admin@trafficai.local
ADMIN_PASSWORD=trafficai-admin-123
OSRM_ROUTE_BASE=https://router.project-osrm.org/route/v1/driving
